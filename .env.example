# ===========================================================================
# wm2026-growth-engine — environment configuration
# Copy to `.env` and fill what you have. EVERYTHING here is optional:
# the system degrades gracefully to free/local/queued fallbacks when a value
# is missing. Nothing crashes for a missing key.
# ===========================================================================

# --- Runtime ---------------------------------------------------------------
ENV=production                 # production | development
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
TZ=UTC
PORT=8080                      # Railway sets this automatically

# --- Database --------------------------------------------------------------
# Railway PostgreSQL plugin provides DATABASE_URL automatically.
# If empty/unreachable, the app falls back to a local SQLite file (data/wm2026.db).
DATABASE_URL=postgresql://wm2026:wm2026@localhost:5432/wm2026

# --- AI: Claude (primary) --------------------------------------------------
# Leave blank to run in template/offline mode (no LLM). System still works.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6        # high-volume default; set claude-opus-4-8 for max quality
CLAUDE_MAX_TOKENS=1200

# --- Football data providers (adapters; first one with a key wins) ---------
# All three have free tiers. football-data.org is the easiest free key.
API_FOOTBALL_KEY=                     # https://www.api-football.com (RapidAPI or direct)
API_FOOTBALL_HOST=v3.football.api-sports.io
FOOTBALL_DATA_KEY=                    # https://www.football-data.org/client/register
SPORTMONKS_KEY=                       # https://www.sportmonks.com

# World Cup 2026 competition identifiers (override if a provider differs)
FOOTBALL_DATA_COMPETITION=WC          # football-data.org code for the World Cup
API_FOOTBALL_LEAGUE_ID=1              # API-Football league id for the World Cup
SEASON=2026

# --- Content / pipeline behaviour -----------------------------------------
VIDEOS_PER_MATCH=5
TARGET_MIN_SECONDS=20
TARGET_MAX_SECONDS=45
HARD_MIN_SECONDS=15
HARD_MAX_SECONDS=60
POLL_INTERVAL_MINUTES=15              # how often the scheduler checks for new/finished matches
DRY_RUN=false                         # true = build videos but never upload
ENABLE_UPLOADS=true                   # master switch for all uploaders

# --- Rights discovery ------------------------------------------------------
# When true, the system probes for legal/free footage before falling back to
# Story Engine Mode. It NEVER touches copyrighted broadcasts regardless.
RIGHTS_DISCOVERY_ENABLED=true
YOUTUBE_DATA_API_KEY=                 # used ONLY to find officially-embeddable / CC-licensed clips

# --- YouTube Shorts upload (official Data API v3, OAuth) -------------------
# Provide the OAuth client JSON path + a pre-authorized refresh token.
# If absent, uploads are queued to the DB instead of failing.
YOUTUBE_CLIENT_SECRETS_FILE=secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public         # public | unlisted | private
YOUTUBE_CATEGORY_ID=17                # 17 = Sports

# --- TikTok upload (official Content Posting API) --------------------------
# Requires an approved developer app. If absent, uploads are queued.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE   # or SELF_ONLY while your app is in sandbox

# --- Team prioritisation (comma-separated, highest first) ------------------
PRIORITY_TEAMS=Germany,England,USA,Argentina,Brazil,France,Portugal,Spain
